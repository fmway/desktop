+static void wlserver_set_libinput_pointer(struct wlr_input_device *device)
+{
+#ifdef HAVE_DRM
+	if (device->type != WLR_INPUT_DEVICE_POINTER || !wlr_input_device_is_libinput(device))
+		return;
+
+	struct libinput_device* libinput_device = wlr_libinput_get_device_handle(device);
+
+	libinput_device_config_tap_set_enabled(libinput_device, g_tapToClick ? LIBINPUT_CONFIG_TAP_ENABLED : LIBINPUT_CONFIG_TAP_DISABLED);
+	libinput_device_config_tap_set_drag_enabled(libinput_device, g_tapAndDrag ? LIBINPUT_CONFIG_DRAG_ENABLED : LIBINPUT_CONFIG_DRAG_DISABLED);
+	libinput_device_config_tap_set_drag_lock_enabled(libinput_device, g_dragLock ? LIBINPUT_CONFIG_DRAG_LOCK_ENABLED : LIBINPUT_CONFIG_DRAG_LOCK_DISABLED);
+	if (libinput_device_config_middle_emulation_is_available(libinput_device)) {
+		libinput_device_config_middle_emulation_set_enabled(libinput_device, g_middleEmu ? LIBINPUT_CONFIG_MIDDLE_EMULATION_ENABLED : LIBINPUT_CONFIG_MIDDLE_EMULATION_DISABLED);
+	}
+	if (libinput_device_config_left_handed_is_available(libinput_device)) {
+		libinput_device_config_left_handed_set(libinput_device, g_leftHanded);
+	}
+	if (libinput_device_config_dwt_is_available(libinput_device)) {
+		libinput_device_config_dwt_set_enabled(libinput_device, g_dwt ? LIBINPUT_CONFIG_DWT_ENABLED : LIBINPUT_CONFIG_DWT_DISABLED);
+	}
+	if (libinput_device_config_dwtp_is_available(libinput_device)) {
+		libinput_device_config_dwtp_set_enabled(libinput_device, g_dwtp ? LIBINPUT_CONFIG_DWTP_ENABLED : LIBINPUT_CONFIG_DWTP_DISABLED);
+	}
+	if (libinput_device_config_scroll_has_natural_scroll(libinput_device) != 0) {
+		auto is_mouse = libinput_device_config_tap_get_finger_count(libinput_device) == 0;
+		if (g_naturalScrolling == SelectedPointerType::ALL || (g_naturalScrolling == SelectedPointerType::MOUSE && is_mouse) || (g_naturalScrolling == SelectedPointerType::TOUCHPAD && !is_mouse)) {
+			libinput_device_config_scroll_set_natural_scroll_enabled(libinput_device, true);
+		}
+	}
+	if (libinput_device_config_accel_is_available(libinput_device)) {
+		libinput_device_config_accel_set_profile(libinput_device, g_accelProfile == PointerAccelProfileType::FLAT ? LIBINPUT_CONFIG_ACCEL_PROFILE_FLAT : LIBINPUT_CONFIG_ACCEL_PROFILE_ADAPTIVE);
+		libinput_device_config_accel_set_speed(libinput_device, g_accelSpeed);
+	}
+#endif
+}
